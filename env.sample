# Copy to `.env.local` at the project root (already gitignored via `.env*`).

# Google AI — required for `/api/gemini` (Tempo AI). Create a key at:
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override cookie signing key (≥16 characters). If unset, a built-in dev default from the repo is used.
TEMPO_SESSION_SECRET=
